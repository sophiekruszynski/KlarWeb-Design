.pdfSteps{
  display:grid;
  gap:14px;
  margin:26px 0;
}

.pdfStep{
  display:grid;
  grid-template-columns:48px 1fr;
  gap:15px;
  align-items:start;
  padding:16px;
  background:var(--bg);
  border:1px solid var(--line);
  border-radius:16px;
}

.pdfStep .stepNo{
  width:42px;
  height:42px;
  margin:0;
}

.pdfStep h3{
  margin-bottom:6px;
}

.pdfStep p{
  margin:0;
  color:var(--muted);
}

.pdfActions{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-top:24px;
}

.projectNotice{
  margin-top:24px;
}

.projectNotice p{
  margin-bottom:8px;
}

@media(max-width:700px){
  .pdfActions{
    display:grid;
  }

  .pdfActions .btn{
    width:100%;
  }
}
